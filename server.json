{
    "name":"FastCFML",
    "openBrowser":true,
    "dockEnable":true,
    "trayEnable":true,
    "debug":false,
    "trace":false,
    "console":false,
    "profile":"dev",
    "env":{},
    "jvm":{
        "heapSize":512,
        "minHeapSize":256
    },
    "web":{
        "host":"localhost",
        "webroot":"root",
        "blockCFAdmin":false,
        "directoryBrowsing":true,
        "accessLogEnable":true,
        "maxRequests":30,
        "gzipEnable":true,
        "bindings":{
            "HTTP":{
                "listen":"3000"
            }
        },
        "rewrites":{
            "enable":true
        }
    },
    "app":{
        "cfengine":"lucee@7.0.2.106"
    }
}
